type UseQueryOptionsWithDefaults<TResult = unknown, TError = ErrorDefault, TDataInitial extends TResult | undefined = undefined> = UseQueryOptions<TResult, TError, TDataInitial> & typeof USE_QUERY_DEFAULTS;

/**
