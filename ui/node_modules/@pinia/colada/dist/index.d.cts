     * Component `__hmrId` to track wrong usage of `useQuery` and warn the user.
     * @internal
     */
    __hmr?: {
        id?: string;
        deps?: Set<EffectScope | ComponentInternalInstance>;
        skip?: boolean;
    };
}
/**
 * Filter to get entries from the cache.
