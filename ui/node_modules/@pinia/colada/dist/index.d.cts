    /**
     * If true, it will only match the exact key, not the children.
     *
     * @example
     * ```ts
     * { key: ['a'], exact: true }
     *  // will match ['a'] but not ['a', 'b'], while
     * { key: ['a'] }
     * // will match both
     * ```
